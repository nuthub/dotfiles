    },

    "temperature": {
	// "thermal-zone": 2,
	"critical-threshold": 95,
	"format": "{icon} {temperatureC}┬░C",
	"format-icons": ["´őë", "´őë", "´őë"]
    },

    "backlight": {
	"device": "intel_backlight",
	"format": "{icon} {percent}%",
	"format-icons": ["´ćů", "´äĹ"]
    },

    "battery": {
	"states": {
	    // "good": 95,
	    "warning": 15,
	    "critical": 10
	},
	"format": " {icon} {capacity}%",
	"format-charging": "{capacity}% ´çŽ",
	"format-plugged": "{capacity}% ´çŽ",
	"format-alt": "{time} {icon}",
	// "format-good": "", // An empty format will hide the module
	// "format-full": "",
	"format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"]
    },

    "wireplumber": {
	"format": "{icon} {volume}%",
	"format-muted": "´ÇŽ",
	"on-click": "pavucontrol",
	"format-icons": ["´ÇŽ", "´Çž", "´ÇĘ"],
	"format-muted": "´ÇŽ"
    },

    "user": {
	"format": "´Çí {work_d}d",
	"interval": 60,
	"height": 30,
	"width": 30,
	"icon": false,
    },
    
    "privacy": {
	"icon-spacing": 4,
	"icon-size": 18,
	"transition-duration": 250
    }
}

