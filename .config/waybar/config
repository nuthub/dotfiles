    "custom/dunst": {
	"exec" : "case $(dunstctl is-paused) in \"false\") echo \"´éó\";; \"true\") echo \"´çĚ\";; esac",
	"interval" : 10,
	"format" : "{icon} {text}",
	"format-icons": {
	    "true": "´éó",
	    "false": "´çĚ"
	},
	"tooltip": true,
	"tooltip-format": "left click: pause / resume",
	"on-click": "dunstctl set-paused toggle && notify-send \"toggled\"",
	// "on-click-right": "rofi-dunst-manager.sh",
    },
    
    "custom/screenshot": {
	"on-click"  : "screenshot.sh -r",
	"on-click-right" : "emacsclient -nc ~/Pictures/Screenshots",
	"tooltip" : true,
	"tooltip-format" : "Take Screenshot",
	"format" : "{icon} {text}",
	"format-icons": "´Ç░"
    },

    "tray": {
	"icon-size": 24,
	"spacing": 4,
	"show-passive-items": true
    },
    
    "clock": {
	"timezone": "Europe/Berlin",
	"locale": "de_DE.utf8",
	"format": "´ü│ W{:%OV  %d.%m.  %H:%M}",
	// ugly hack because of https://github.com/Alexays/Waybar/issues/2240#issuecomment-2064237563
	// Example:            10 11 12 13 14 15 16 W00   10 11 12 13 14 15 16 W00   10 11 12 13 14 15 16 W00 
	"tooltip-format": "<tt>                                                                              \n{calendar}</tt>",
	"calendar" : {
	    "mode": "year",
	    "weeks-pos": "left",
	    "mode-mon-col": 3, // https://github.com/Alexays/Waybar/issues/2240
	    "format": {
		"months":     "<span color='#ffead3'><b>{}</b></span>",
		"days":       "<span color='#dddddd'><b>{}</b></span>",
		"weeks":      "<span color='#11BB11'>W{:%OV}</span>",
		"weekdays":   "<span color='#ffcc66'><b>{}</b></span>",
		"today":      "<span color='#ff6699'><b><u>{}</u></b></span>"
	    }
	},
	"actions" : {
	    "on-click" : "mode"
	}	
    },

    "cpu": {
	"format": "´őŤ {usage}% {icon}",
	"format-icons": ["Ôľü", "Ôľé", "Ôľâ", "Ôľä", "Ôľů", "Ôľć", "Ôľç", "Ôľł"],
	"tooltip": true,
	"on-click": "alacritty -e htop"
