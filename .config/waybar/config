// -*- mode: js; -*-

{
    "ipc": true,
    "height": 36, // Waybar height (to be removed for auto height)
    "spacing": 8,// Gaps between modules (default: 4)
    // "layer": "top", // Waybar at top layer
    "position": "top", // Waybar position (top|bottom|left|right)
    // "width": 1280, // Waybar width
    // Choose the order of the modules
    "modules-left": ["sway/workspaces", "sway/mode", "sway/scratchpad", "sway/window", "niri/workspaces", "niri/window"],
    "modules-center": [],
    "modules-right": ["custom/connections", "battery", "temperature", "power-profiles-daemon", "backlight", "wireplumber", "user", "clock", "custom/pomodoro", "custom/doorstatus", "tray", "custom/screenshot", "privacy", "idle_inhibitor", "custom/dunst"],

    "sway/workspaces": {
	"disable-scroll": true    
    },

    "sway/mode": {
	"format": "{}"
    },

    "sway/scratchpad": {
	"format": "{icon} {count}",
	"show-empty": false,
	"format-icons": ["", "´őĺ"],
	"tooltip": true,
	"tooltip-format": "{app}: {title}"
    },

    // see also https://github.com/Alexays/Waybar/issues/1712#issuecomment-1803911617
    "sway/window": {
	"format": "{shell}@@{app_id}@@{title}",
	"rewrite": {
	    "@@@@": "", // in case no window is focused
	    "(xwayland)@@(.*)@@(.*)": "[X:$2] $3", // format app_id for X apps
	    "(xdg_shell)@@(.*)@@(.*)": "[$2] $3", // format app_id for wayland apps
	}
    },

    "idle_inhibitor": {
	"format": "{icon}",
	"format-icons": {
	    "activated": "´ü«",
	    "deactivated": "´ü░"
	}
    },

    "power-profiles-daemon": {
	"format": "{icon}",
	"tooltip-format": "Power profile: {profile}\nDriver: {driver}",
	"tooltip": true,
	"format-icons": {
	    "default": "´âž",
	    "performance": "<span color=\"#FF9999\">´âž</span>",
	    "balanced": "´ëÄ",
	    "power-saver": "<span color=\"#99FFFF\">´üČ</span>"
	}
    },

    "custom/connections": {
	"on-click" : "~/.config/waybar/get_connections.sh",
	"exec": "~/.config/waybar/get_connections.sh",
	"interval": 10,
	"format" : "{icon} {text}",
	"format-icons": "´Ť┐"
    },

    "custom/doorstatus": {
	"on-click" : "~/.local/bin/doorstatus.sh",
	"exec": "~/.local/bin/doorstatus.sh",
	"class": "custom-doorstatus",
	"interval": 60
    },

    "custom/pomodoro": {
	"exec" : "org-pomodoro-state.sh",
	"return-type" : "json",
	"interval" : 1,
	"format" : "­čŹů {}",
	"hide-empty-text" : true,
	"on-click" : "emacsclient -nc -e '(org-clock-goto)'",
	"class" : "custom-pomodoro"
    },
    
    "network": {
	"interface" : "wlp9s0f0",
	"interval": 2,
	"tooltip-format": "{ifname} ÔćĹ{bandwidthUpBytes} Ôćô{bandwidthDownBytes}",
	"format": "{essid}",
	"format-disconnected": ""
    },

